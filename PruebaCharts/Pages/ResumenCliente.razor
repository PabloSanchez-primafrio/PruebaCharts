@code {
    private string? nombreCliente;
    private int clienteId = 212;
    private List<PaletsTotales>? todosLosDatos;
    private List<Facturacion>? todaFacturacion;
    private List<NumViajes>? todosLosViajes;

    private double mediaOcupacion = 0;
    private double kpiKmTotal = 0;
    private int kpiCargas = 0;
    private int kpiDescargas = 0;
    private int kpiViajes = 0;
    private int kpiPalets = 0;
    private float kpiFacturacion = 0;
    private bool cargando = true;
    private bool _disposed = false;

    private List<(string pais, int count)> topPaisesCarga = new();
    private List<(string pais, int count)> topPaisesDescarga = new();

    private ModoFiltro modoFiltro = ModoFiltro.MesAnio;
    private enum ModoFiltro { MesAnio, Rango }

    private bool dropdownAniosAbierto = false;
    private bool dropdownMesesAbierto = false;

    private List<int>? aniosDisponibles = null;
    private HashSet<int> aniosSeleccionados = new();
    private HashSet<int> mesesSeleccionados = new();

    private List<string> nombresMeses = new()
    {
        "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"
    };

    private DateTime? fechaDesde;
    private DateTime? fechaHasta;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        await RenderizarTodo();
    }

    private async Task CargarDatos()
    {
        try
        {
            todosLosDatos = await ConsultaService.GetCarga(clienteId);
            todaFacturacion = await ConsultaService.GetFacturacion(clienteId);
            todosLosViajes = await ConsultaService.GetNumViajes(clienteId);
            nombreCliente = todosLosDatos.First().NombreCliente;
            aniosDisponibles = todosLosDatos
                .Select(d => d.FechaTrabajo.Year)
                .Distinct()
                .OrderByDescending(a => a)
                .ToList();

            CalcularKpis(todosLosDatos, todaFacturacion, todosLosViajes);
            cargando = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando datos: {ex.Message}");
            aniosDisponibles = new List<int>();
            cargando = false;
        }
        finally
        {
            StateHasChanged();
        }
    }

    private void CalcularKpis(IEnumerable<PaletsTotales> datos, IEnumerable<Facturacion> facturacion, IEnumerable<NumViajes> viajes)
    {
        var europalet = new HashSet<string> { "H", "E", "N", "NE" };

        kpiViajes = viajes.Sum(v => v.NumeroViajes);
        kpiCargas = datos.Where(d => !string.IsNullOrEmpty(d.PaisCarga)).GroupBy(d => d.NombreLugarCarga).Count();
        kpiDescargas = datos.Where(d => !string.IsNullOrEmpty(d.PaisDescarga)).GroupBy(d => d.NombreLugarDescarga).Count();
        kpiPalets = datos.Sum(d => d.NumeroPalets);
        kpiKmTotal = datos.GroupBy(d => d.Trayecto).Sum(g => (double) g.First().KmTotal);

        kpiFacturacion = facturacion.Sum(f => f.Vtotal);

        topPaisesCarga = datos
            .Where(d => !string.IsNullOrEmpty(d.PaisCarga))
            .GroupBy(d => d.PaisCarga.Trim())
            .Select(g => (Pais: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            //.Take(3)
            .ToList();

        topPaisesDescarga = datos
            .Where(d => !string.IsNullOrEmpty(d.PaisDescarga))
            .GroupBy(d => d.PaisDescarga.Trim())
            .Select(g => (Pais: g.Key, Count: g.Count()))
            .OrderByDescending(x => x.Count)
            //.Take(3)
            .ToList();

        var ocupacionesPorViaje = datos
            .GroupBy(d => d.Trayecto)
            .Select(g =>
            {
                double capacidad = europalet.Contains(g.First().TipoPalets) ? 33.0 : 26.0;
                double paletsTotales = g.Sum(d => (double)d.NumeroPalets);
                return capacidad > 0 ? paletsTotales / capacidad * 100 : 0.0;
            })
            .ToList();

        mediaOcupacion = ocupacionesPorViaje.Any()
            ? Math.Round(ocupacionesPorViaje.Average(), 1)
            : 0;
    }

    private IEnumerable<PaletsTotales> AplicarFiltrosDatos()
    {
        if (todosLosDatos is null) return Enumerable.Empty<PaletsTotales>();

        var resultado = todosLosDatos.AsEnumerable();

        if (modoFiltro == ModoFiltro.MesAnio)
        {
            if (aniosSeleccionados.Any())
                resultado = resultado.Where(d => aniosSeleccionados.Contains(d.FechaTrabajo.Year));
            if (mesesSeleccionados.Any())
                resultado = resultado.Where(d => mesesSeleccionados.Contains(d.FechaTrabajo.Month));
        }
        else
        {
            if (fechaDesde.HasValue)
                resultado = resultado.Where(d => d.FechaTrabajo >= fechaDesde.Value);
            if (fechaHasta.HasValue)
                resultado = resultado.Where(d => d.FechaTrabajo <= fechaHasta.Value);
        }

        return resultado;
    }

    private IEnumerable<Facturacion> AplicarFiltrosFacturacion()
    {
        if (todaFacturacion is null) return Enumerable.Empty<Facturacion>();

        var resultado = todaFacturacion.AsEnumerable();

        if(modoFiltro == ModoFiltro.MesAnio)
        {
            if (aniosSeleccionados.Any())
                resultado = resultado.Where(d => aniosSeleccionados.Contains(d.FechaPedido.Year));
            if (mesesSeleccionados.Any())
                resultado = resultado.Where(d => mesesSeleccionados.Contains(d.FechaPedido.Month));
        }
        else
        {
            if (fechaDesde.HasValue)
                resultado = resultado.Where(f => f.FechaPedido >= fechaDesde.Value);
            if (fechaHasta.HasValue)
                resultado = resultado.Where(f => f.FechaPedido <= fechaHasta.Value);
        }

        return resultado;
    }

    private IEnumerable<NumViajes> AplicarFiltrosViajes()
    {
        if (todosLosViajes is null) return Enumerable.Empty<NumViajes>();

        var resultado = todosLosViajes.AsEnumerable();

        if(modoFiltro == ModoFiltro.MesAnio)
        {
            if (aniosSeleccionados.Any())
                resultado = resultado.Where(v => aniosSeleccionados.Contains(v.Anyo));
            if (mesesSeleccionados.Any())
                resultado = resultado.Where(v => mesesSeleccionados.Contains(v.Mes));
        }
        else
        {
            if (fechaDesde.HasValue)
                resultado = resultado.Where(v => new DateTime(v.Anyo, v.Mes, 1) >= fechaDesde.Value.Date);
            if (fechaHasta.HasValue)
                resultado = resultado.Where(v => new DateTime(v.Anyo, v.Mes, 1) <= fechaHasta.Value.Date);
        }
        return resultado;
    }

    private string TextoBotonAnios => aniosSeleccionados.Count == 0
        ? "Todos los años"
        : aniosSeleccionados.Count == 1
            ? aniosSeleccionados.First().ToString()
            : $"{aniosSeleccionados.Count} años";

    private string TextoBotonMeses => mesesSeleccionados.Count == 0
        ? "Todos los meses"
        : mesesSeleccionados.Count == 1
            ? nombresMeses[mesesSeleccionados.First() - 1]
            : $"{mesesSeleccionados.Count} meses";

    private bool HayFiltrosActivos =>
        modoFiltro == ModoFiltro.MesAnio
            ? aniosSeleccionados.Any() || mesesSeleccionados.Any()
            : fechaDesde.HasValue || fechaHasta.HasValue;

    private void ToggleDropdownAnios()
    {
        dropdownAniosAbierto = !dropdownAniosAbierto;
        dropdownMesesAbierto = false;
    }

    private void ToggleDropdownMeses()
    {
        dropdownMesesAbierto = !dropdownMesesAbierto;
        dropdownAniosAbierto = false;
    }

    private async Task ToggleAnio(int anio, bool seleccionado)
    {
        if (seleccionado) aniosSeleccionados.Add(anio);
        else aniosSeleccionados.Remove(anio);
        await AplicarFiltros();
    }

    private async Task ToggleMes(int mes, bool seleccionado)
    {
        if (seleccionado) mesesSeleccionados.Add(mes);
        else mesesSeleccionados.Remove(mes);
        await AplicarFiltros();
    }

    private async Task SeleccionarTodosAnios() { aniosSeleccionados = aniosDisponibles!.ToHashSet(); await AplicarFiltros(); }
    private async Task LimpiarAnios() { aniosSeleccionados.Clear(); await AplicarFiltros(); }
    private async Task SeleccionarTodosMeses() { mesesSeleccionados = Enumerable.Range(1, 12).ToHashSet(); await AplicarFiltros(); }
    private async Task LimpiarMeses() { mesesSeleccionados.Clear(); await AplicarFiltros(); }

    private async Task OnFechaDesdeChanged(ChangeEventArgs e)
    {
        fechaDesde = DateTime.TryParse(e.Value?.ToString(), out var f) ? f : null;
        await AplicarFiltros();
    }

    private async Task OnFechaHastaChanged(ChangeEventArgs e)
    {
        fechaHasta = DateTime.TryParse(e.Value?.ToString(), out var f) ? f : null;
        await AplicarFiltros();
    }

    private async Task LimpiarRango()
    {
        fechaDesde = fechaHasta = null;
        await AplicarFiltros();
    }

    private async Task SetModoFiltro(ModoFiltro modo)
    {
        modoFiltro = modo;
        dropdownAniosAbierto = dropdownMesesAbierto = false;
        await AplicarFiltros();
    }

    private async Task AplicarFiltros()
    {
        var datosFiltrados = AplicarFiltrosDatos();
        var factFiltrada = AplicarFiltrosFacturacion();
        var viajesFiltrados = AplicarFiltrosViajes();
        CalcularKpis(datosFiltrados, factFiltrada, viajesFiltrados);
        StateHasChanged();
        await RenderizarTodo();
    }

    private string GetGaugeColor(double pct)
    {
        if (pct <= 50)
        {
            double t = pct / 50;
            return InterpolateColor("#D64550", "#E68F37", t);
        }
        else
        {
            double t = (pct - 50) / 50;
            return InterpolateColor("#E68F37", "#39B546", t);
        }
    }

    private string InterpolateColor(string hex1, string hex2, double t)
    {
        (int r1, int g1, int b1) = HexToRgb(hex1);
        (int r2, int g2, int b2) = HexToRgb(hex2);
        int r = (int)(r1 + (r2 - r1) * t);
        int g = (int)(g1 + (g2 - g1) * t);
        int b = (int)(b1 + (b2 - b1) * t);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private (int r, int g, int b) HexToRgb(string hex)
    {
        hex = hex.Replace("#", "");
        return (
            Convert.ToInt32(hex.Substring(0, 2), 16),
            Convert.ToInt32(hex.Substring(2, 2), 16),
            Convert.ToInt32(hex.Substring(4, 2), 16)
        );
    }

    private async Task RenderizarGauge()
    {
        if (_disposed) return;

        string color = GetGaugeColor(mediaOcupacion);

        var options = new
        {
            series = new[]
            {
                new
                {
                    type = "gauge",
                    startAngle = 210,
                    endAngle = -30,
                    min = 0,
                    max = 100,
                    radius = "88%",
                    center = new[] { "50%", "58%" },
                    progress = new
                    {
                        show = true,
                        width = 18,
                        itemStyle = new { color = color }
                    },
                    axisLine = new
                    {
                        lineStyle = new
                        {
                            width = 18,
                            color = new object[] { new object[] { 1, "#babcbf" } }
                        }
                    },
                    pointer   = new { show = false },
                    axisTick  = new { show = false },
                    splitLine = new { show = false },
                    axisLabel = new { show = false },
                    detail = new
                    {
                        valueAnimation = true,
                        formatter      = "{value}%",
                        color          = color,
                        fontSize       = 28,
                        fontWeight     = "bold",
                        offsetCenter   = new[] { "0%", "10%" }
                    },
                    title = new
                    {
                        show         = true,
                        offsetCenter = new[] { "0%", "40%" },
                        fontSize     = 13,
                        color        = "000000",
                        fontWeight   = "bold"
                    },
                    data = new[] { new { value = mediaOcupacion } }
                }
            }
        };

        try
        {
            await JS.InvokeVoidAsync("renderEChart", "gaugeOcupacion", options);
        }
        catch (JSDisconnectedException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"Error gauge: {ex.Message}");
        }
    }

    private async Task RenderizarChartViajes()
    {
        if (_disposed || todosLosDatos is null) return;
        var filtrados = AplicarFiltrosViajes().ToList();
        var datos = Enumerable.Range(1, 12).Select(mes => new
        {
            label = nombresMeses[mes - 1][..3],
            value = filtrados.Where(v => v.Mes == mes).Sum(v => v.NumeroViajes)
        }).ToList();

        var options = new
        {
            grid = new { top = 15, bottom = 25, left = 45, right = 15 },
            xAxis = new { type = "category", data = datos.Select(d => d.label).ToArray(), axisLabel = new { fontSize = 11 } },
            yAxis = new { type = "value", axisLabel = new { fontSize = 11 } },
            series = new[] { new
            {
                type = "line", smooth = true,
                data = datos.Select(d => d.value).ToArray(),
                lineStyle = new { color = "#06038D", width = 2 },
                itemStyle = new { color = "#06038D" },
                areaStyle = new { color = "#FFF099" }
            }}
        };

        try
        {
            await JS.InvokeVoidAsync("renderEChart", "chartViajes", options);
        }
        catch (JSDisconnectedException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"chartViajes: {ex.Message}");
        }
    }

    private async Task RenderizarChartFacturacion()
    {
        if (_disposed || todaFacturacion is null) return;
        var filtrados = AplicarFiltrosFacturacion().ToList();
        var datos = Enumerable.Range(1, 12).Select(mes => new
        {
            label = nombresMeses[mes - 1][..3],
            value = filtrados.Where(f => f.FechaPedido.Month == mes).Sum(f => f.Vtotal)
        }).ToList();

        var options = new
        {
            grid = new { top = 15, bottom = 25, left = 60, right = 15 },
            xAxis = new { type = "category", data = datos.Select(d => d.label).ToArray(), axisLabel = new { fontSize = 11 } },
            yAxis = new { type = "value", axisLabel = new { fontSize = 11, formatter = "{value}€" } },
            series = new[] { new
            {
                type = "bar", barMaxWidth = 35,
                data = datos.Select(d => d.value).ToArray(),
                itemStyle = new { color = "#287233" }
            }}
        };

        try
        {
            await JS.InvokeVoidAsync("renderEChart", "chartFacturacion", options);
        }
        catch (JSDisconnectedException) { }
        catch (Exception ex)
        {
            Console.WriteLine($"chartFacturacion: {ex.Message}");
        }
    }

    private async Task RenderizarChartPalets()
    {
        if (_disposed || todosLosDatos is null) return;
        var filtrados = AplicarFiltrosDatos().ToList();
        var datos = Enumerable.Range(1, 12).Select(mes => new
        {
            label = nombresMeses[mes - 1][..3],
            value = filtrados.Where(d => d.FechaTrabajo.Month == mes).Sum(d => d.NumeroPalets)
        }).ToList();

        var options = new
        {
            grid = new { top = 15, bottom = 25, left = 45, right = 15},

@page "/resumen"
@using System.Threading.Tasks

@inject IJSRuntime JS
@inject ConsultaService ConsultaService

<PageTitle>Resumen Cliente</PageTitle>

<div class="d-flex justify-content-between align-items-center">
    <h1 style="color:#06038D">
        <strong>
            <svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -900 960 960" width="40px" fill="#06038D">
                <path d="M520-600v-240h320v240H520ZM120-440v-400h320v400H120Zm400 320v-400h320v400H520Zm-400 0v-240h320v240H120Zm80-400h160v-240H200v240Zm400 320h160v-240H600v240Zm0-480h160v-80H600v80ZM200-200h160v-80H200v80Zm160-320Zm240-160Zm0 240ZM360-280Z" />
            </svg>
            Resumen - @nombreCliente
        </strong>
    </h1>
    <div class="card" style="margin-bottom:20px;">
        <div class="card-body py-1">
            <div class="d-flex align-items-center gap-3 flex-wrap">

                <div class="d-flex align-items-center gap-2">
                    <span class="fw-semibold small" style="color:#06038D">Filtrar por:</span>
                    <div class="btn-group" role="group">
                        <button type="button"
                                class="btn btn-sm @(modoFiltro == ModoFiltro.MesAnio ? "btn-primary" : "btn-outline-primary")"
                                style="@(modoFiltro == ModoFiltro.MesAnio ? "background-color:#06038D; border-color:#06038D;" : "color:#06038D; border-color:#06038D;")"
                                @onclick="async () => await SetModoFiltro(ModoFiltro.MesAnio)">
                            <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -900 960 960" width="16px" fill="currentColor">
                                <path d="M580-240q-42 0-71-29t-29-71q0-42 29-71t71-29q42 0 71 29t29 71q0 42-29 71t-71 29ZM200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v560q0 33-23.5 56.5T760-80H200Zm0-80h560v-400H200v400Zm0-480h560v-80H200v80Zm0 0v-80 80Z" />
                            </svg>
                            Mes / Año
                        </button>
                        <button type="button"
                                class="btn btn-sm @(modoFiltro == ModoFiltro.Rango ? "btn-primary" : "btn-outline-primary")"
                                style="@(modoFiltro == ModoFiltro.Rango ? "background-color:#06038D; border-color:#06038D;" : "color:#06038D; border-color:#06038D;")"
                                @onclick="async () => await SetModoFiltro(ModoFiltro.Rango)">
                            <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -780 960 960" width="16px" fill="currentColor">
                                <path d="M120-160v-80h240v-160H120v-80h240q33 0 56.5 23.5T440-400v40h80v-40q0-33 23.5-56.5T600-480h240v80H600v160h240v80H600q-33 0-56.5-23.5T520-240v-40h-80v40q0 33-23.5 56.5T360-160H120Z" />
                            </svg>
                            Rango de fechas
                        </button>
                    </div>
                </div>

                <div class="vr mx-1" style="height:36px;"></div>

                @if (modoFiltro == ModoFiltro.MesAnio)
                {
                    <div class="dropdown" @onclick:stopPropagation>
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center gap-1"
                                type="button"
                                @onclick="ToggleDropdownAnios"
                                style="border-color:#dee2e6; min-width:140px;">
                            <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="#06038D">
                                <path d="M216-96q-29.7 0-50.85-21.15Q144-138.3 144-168v-528q0-29.7 21.15-50.85Q186.3-768 216-768h72v-96h72v96h240v-96h72v96h72q29.7 0 50.85 21.15Q816-725.7 816-696v528q0 29.7-21.15 50.85Q773.7-96 744-96H216Zm0-72h528v-360H216v360Z" />
                            </svg>
                            @TextoBotonAnios
                            @if (aniosSeleccionados.Any())
                            {
                                <span class="badge rounded-pill ms-1" style="background-color:#06038D; font-size:10px;">@aniosSeleccionados.Count</span>
                            }
                        </button>
                        @if (dropdownAniosAbierto)
                        {
                            <div class="dropdown-menu show shadow p-2" style="min-width:160px; z-index:1050;">
                                <div class="px-2 pb-1 mb-1 border-bottom">
                                    <small class="text-muted fw-semibold">Años</small>
                                </div>
                                @if (aniosDisponibles is null)
                                {
                                    <div class="px-3 py-2 text-muted small">Cargando...</div>
                                }
                                else if (!aniosDisponibles.Any())
                                {
                                    <div class="px-3 py-2 text-muted small">Sin datos</div>
                                }
                                else
                                {
                                    @foreach (var anio in aniosDisponibles)
                                    {
                                        <div class="form-check mx-2 py-1">
                                            <input class="form-check-input" type="checkbox"
                                                   id="anio-@anio"
                                                   checked="@aniosSeleccionados.Contains(anio)"
                                                   @onchange="async e => await ToggleAnio(anio, (bool)e.Value!)" />
                                            <label class="form-check-label" for="anio-@anio">@anio</label>
                                        </div>
                                    }
                                    <div class="border-top mt-1 pt-1 px-2 d-flex gap-1">
                                        <button class="btn btn-link btn-sm p-0 text-decoration-none" style="color:#06038D; font-size:11px;" @onclick="async () => await SeleccionarTodosAnios()">Todos</button>
                                        <span class="text-muted" style="font-size:11px;">|</span>
                                        <button class="btn btn-link btn-sm p-0 text-decoration-none text-muted" style="font-size:11px;" @onclick="async () => await LimpiarAnios()">Ninguno</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="dropdown" @onclick:stopPropagation>
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center gap-1"
                                type="button"
                                @onclick="ToggleDropdownMeses"
                                style="border-color:#dee2e6; min-width:150px;">
                            <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="#06038D">
                                <path d="M580-240q-42 0-71-29t-29-71q0-42 29-71t71-29q42 0 71 29t29 71q0 42-29 71t-71 29ZM200-80q-33 0-56.5-23.5T120-160v-560q0-33 23.5-56.5T200-800h40v-80h80v80h320v-80h80v80h40q33 0 56.5 23.5T840-720v560q0 33-23.5 56.5T760-80H200Zm0-80h560v-400H200v400Zm0-480h560v-80H200v80Zm0 0v-80 80Z" />
                            </svg>
                            @TextoBotonMeses
                            @if (mesesSeleccionados.Any())
                            {
                                <span class="badge rounded-pill ms-1" style="background-color:#06038D; font-size:10px;">@mesesSeleccionados.Count</span>
                            }
                        </button>
                        @if (dropdownMesesAbierto)
                        {
                            <div class="dropdown-menu show shadow p-2" style="min-width:170px; z-index:1050;">
                                <div class="px-2 pb-1 mb-1 border-bottom">
                                    <small class="text-muted fw-semibold">Meses</small>
                                </div>
                                @foreach (var mes in nombresMeses)
                                {
                                    var numMes = nombresMeses.IndexOf(mes) + 1;
                                    <div class="form-check mx-2 py-1">
                                        <input class="form-check-input" type="checkbox"
                                               id="mes-@numMes"
                                               checked="@mesesSeleccionados.Contains(numMes)"
                                               @onchange="async e => await ToggleMes(numMes, (bool)e.Value!)" />
                                        <label class="form-check-label" for="mes-@numMes">@mes</label>
                                    </div>
                                }
                                <div class="border-top mt-1 pt-1 px-2 d-flex gap-1">
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none" style="color:#06038D; font-size:11px;" @onclick="async () => await SeleccionarTodosMeses()">Todos</button>
                                    <span class="text-muted" style="font-size:11px;">|</span>
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none text-muted" style="font-size:11px;" @onclick="async () => await LimpiarMeses()">Ninguno</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="d-flex align-items-center gap-1">
                            <label class="form-label mb-0 small fw-semibold text-muted">Desde</label>
                            <input type="date" class="form-control form-control-sm"
                                   style="width:150px; border-color:#dee2e6;"
                                   value="@fechaDesde?.ToString("yyyy-MM-dd")"
                                   max="@fechaHasta?.ToString("yyyy-MM-dd")"
                                   @onchange="async e => await OnFechaDesdeChanged(e)" />
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <label class="form-label mb-0 small fw-semibold text-muted">Hasta</label>
                            <input type="date" class="form-control form-control-sm"
                                   style="width:150px; border-color:#dee2e6;"
                                   value="@fechaHasta?.ToString("yyyy-MM-dd")"
                                   min="@fechaDesde?.ToString("yyyy-MM-dd")"
                                   @onchange="async e => await OnFechaHastaChanged(e)" />
                        </div>
                        @if (fechaDesde.HasValue || fechaHasta.HasValue)
                        {
                            <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none" @onclick="async () => await LimpiarRango()">
                                <svg xmlns="http://www.w3.org/2000/svg" height="18px" viewBox="0 -960 960 960" width="18px" fill="currentColor">
                                    <path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z" />
                                </svg>
                            </button>
                        }
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M160-120q-50 0-85-35t-35-85q0-26 10-49.5T80-330v-190h80v-240h320l188 443q6 14 9 28t3 29q0 58-41 99t-99 41q-41 0-75.5-21.5T413-200H273q-13 36-44 58t-69 22Zm560-40v-640h80v560h120v80H720Zm-531.5-51.5Q200-223 200-240t-11.5-28.5Q177-280 160-280t-28.5 11.5Q120-257 120-240t11.5 28.5Q143-200 160-200t28.5-11.5Zm394-6Q600-235 600-260t-17.5-42.5Q565-320 540-320t-42.5 17.5Q480-285 480-260t17.5 42.5Q515-200 540-200t42.5-17.5ZM273-280h128q2-11 4.5-20.5T413-320h-90L206-440h-46v80q38 0 69 22t44 58Zm84-120h189L427-680H240v160l117 120Zm-34 80-18.5-19q-18.5-19-40-41.5t-40-41L206-440h-46 46l117 120h90-90Z" /></svg>
                <span class="text-white fw-semibold"><strong> Nº Cargas</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiCargas.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="m720-80 120-120-28-28-72 72v-164h-40v164l-72-72-28 28L720-80ZM480-800 243-663l237 137 237-137-237-137ZM120-321v-318q0-22 10.5-40t29.5-29l280-161q10-5 19.5-8t20.5-3q11 0 21 3t19 8l280 161q19 11 29.5 29t10.5 40v159h-80v-116L479-434 200-596v274l240 139v92L160-252q-19-11-29.5-29T120-321ZM578.5-58.5Q520-117 520-200t58.5-141.5Q637-400 720-400t141.5 58.5Q920-283 920-200T861.5-58.5Q803 0 720 0T578.5-58.5ZM480-491Z" /></svg>
                <span class="text-white fw-semibold"><strong>Nº Descargas</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiDescargas.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M307-113.5Q240-147 240-200q0-24 14.5-44.5T295-280l63 59q-9 4-19.5 9T322-200q13 16 60 28t98 12q51 0 98.5-12t60.5-28q-7-8-18-13t-21-9l62-60q28 16 43 36.5t15 45.5q0 53-67 86.5T480-80q-106 0-173-33.5ZM481-300q99-73 149-146.5T680-594q0-102-65-154t-135-52q-70 0-135 52t-65 154q0 67 49 139.5T481-300Zm-1 100Q339-304 269.5-402T200-594q0-71 25.5-124.5T291-808q40-36 90-54t99-18q49 0 99 18t90 54q40 36 65.5 89.5T760-594q0 94-69.5 192T480-200Zm0-320q33 0 56.5-23.5T560-600q0-33-23.5-56.5T480-680q-33 0-56.5 23.5T400-600q0 33 23.5 56.5T480-520Zm0-80Z" /></svg>
                <span class="text-white fw-semibold"><strong>Nº Viajes</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiViajes.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M80-80v-160h800v160H760v-80H540v80H420v-80H200v80H80Zm160-240q-17 0-28.5-11.5T200-360v-480q0-17 11.5-28.5T240-880h480q17 0 28.5 11.5T760-840v480q0 17-11.5 28.5T720-320H240Zm40-80h400v-400H280v400Zm80-240h240v-80H360v80Zm-80 240v-400 400Z" /></svg>
                <span class="text-white fw-semibold"><strong>Nº Palets</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiPalets.ToString("N0") Palets</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M440-200h80v-40h40q17 0 28.5-11.5T600-280v-120q0-17-11.5-28.5T560-440H440v-40h160v-80h-80v-40h-80v40h-40q-17 0-28.5 11.5T360-520v120q0 17 11.5 28.5T400-360h120v40H360v80h80v40ZM240-80q-33 0-56.5-23.5T160-160v-640q0-33 23.5-56.5T240-880h320l240 240v480q0 33-23.5 56.5T720-80H240Zm280-560v-160H240v640h480v-480H520ZM240-800v160-160 640-640Z" /></svg>
                <span class="text-white fw-semibold"><strong>Facturación</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiFacturacion.ToString("N0") €</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden" style="text-align:center;">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M247-167q-47-47-47-113v-327q-35-13-57.5-43.5T120-720q0-50 35-85t85-35q50 0 85 35t35 85q0 39-22.5 69.5T280-607v327q0 33 23.5 56.5T360-200q33 0 56.5-23.5T440-280v-400q0-66 47-113t113-47q66 0 113 47t47 113v327q35 13 57.5 43.5T840-240q0 50-35 85t-85 35q-50 0-85-35t-35-85q0-39 22.5-70t57.5-43v-327q0-33-23.5-56.5T600-760q-33 0-56.5 23.5T520-680v400q0 66-47 113t-113 47q-66 0-113-47Zm-7-513q17 0 28.5-11.5T280-720q0-17-11.5-28.5T240-760q-17 0-28.5 11.5T200-720q0 17 11.5 28.5T240-680Zm480 480q17 0 28.5-11.5T760-240q0-17-11.5-28.5T720-280q-17 0-28.5 11.5T680-240q0 17 11.5 28.5T720-200ZM240-720Zm480 480Z" /></svg>
                <span class="text-white fw-semibold"><strong>Kilómetros</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div class="fs-4 fw-bold" style="color:#06038D;">@kpiKmTotal.ToString("N0") Km</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -960 960 960" width="20px" fill="white"><path d="m147-237-51-51 288-288 157 156 269-302 54 48-320 360-160-160-237 237Z" /></svg>
                <span class="text-white fw-semibold"><strong>Viajes por Mes</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div id="chartViajes" style="width:100%; height:300px;"></div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white"><path d="M200-120q-33 0-56.5-23.5T120-200v-640h80v640h640v80H200Zm40-120v-360h160v360H240Zm200 0v-560h160v560H440Zm200 0v-200h160v200H640Z" /></svg>
                <span class="text-white fw-semibold"><strong>Facturación Mensual</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div id="chartFacturacion" style="width:100%; height:300px;"></div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-1 shadow-sm overflow-hidden">
            <div class="card-header" style="background-color:#06038D;">
                <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -920 960 960" width="20px" fill="white"><path d="M155-227q-35-35-35-85H48v-408q0-29.7 21.15-50.85Q90.3-792 120-792h552v144h120l120 168v168h-72q0 50-35 85t-85 35q-50 0-85-35t-35-85H360q0 50-35 85t-85 35q-50 0-85-35Zm119-51q14-14 14-34t-14-34q-14-14-34-14t-34 14q-14 14-14 34t14 34q14 14 34 14t34-14ZM120-384h24q17-23 42-35.5t54-12.5q29 0 54 12.5t41.53 35.5H600v-336H120v336Zm634 106q14-14 14-34t-14-34q-14-14-34-14t-34 14q-14 14-14 34t14 34q14 14 34 14t34-14Zm-82-178 168-1-85-119h-83v120Zm-310-93Z" /></svg>
                <span class="text-white fw-semibold"><strong>Palets Transportados</strong></span>
            </div>
            <div class="card-body px-3 py-2">
                <div id="chartPalets" style="width:100%; height:300px;"></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-4 col-lg-2">
        <div class="card h-100 border-1 shadow-sm">
            <div class="card-header" style="background-color:#06038D; color:white;">
                <h6 class="mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" height="20px" viewBox="0 -900 960 960" width="20px" fill="white">
